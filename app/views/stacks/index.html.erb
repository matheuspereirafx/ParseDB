
<%# app/views/stacks/index.html.erb %>

<div class="sf-page">
  <div class="sf-glow"></div>

  <section class="sf-stacks-section">
    <h1 class="sf-stacks-title">Choose your tool</h1>
    <p class="sf-stacks-subtitle">Select a stack to get started</p>

    <div class="sf-stacks-grid">
      <% @stacks.each do |stack| %>
        <div class="sf-stack-card">
          <!-- ÍCONE E NOME NA MESMA LINHA -->
          <h5 class="sf-stack-name">
            <span class="sf-stack-icon">
              <% if stack.name.downcase.include?("seed") %>
                🌱
              <% elsif stack.name.downcase.include?("schema") %>
                🗂️
              <% elsif stack.name.downcase.include?("database") %>
                💾
              <% else %>
                📄
              <% end %>
            </span>
            <%= stack.name %>
          </h5>

          <p class="sf-stack-description"><%= stack.description %></p>
          <%= link_to "Open Chat", stack_chat_path(stack), class: "sf-btn-primary" %>
        </div>
      <% end %>
    </div>
  </section>
</div>
