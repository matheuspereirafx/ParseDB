<div class="sf-page">
  <div class="sf-glow"></div>

  <!-- HERO -->
  <section class="sf-hero">
    <div class="sf-badge">
      <span class="sf-badge-dot"></span>
      AI-Powered · Built for Le Wagon
    </div>
    <h1>
      User Stories<br>
      <span class="sf-gradient-text">Database Schema</span>
    </h1>
    <p class="sf-hero-subtitle">
      Descreve o teu projeto em linguagem natural. A IA gera o
      schema, o diagrama visual, o XML para db.lewagon.org e seeds
      realistas.
    </p>
    <div class="sf-hero-buttons">
      <%= link_to "#", class: "sf-btn-primary" do %>
        🗂️ Schema
      <% end %>
      <%= link_to "#", class: "sf-btn-primary" do %>
        🌱 Seeds
      <% end %>
      <%= link_to "#", class: "sf-btn-primary" do %>
        📄 DataBase
      <% end %>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="sf-footer">
    Feito com 💜 por Equipa ParseDB · Le Wagon 2026 ·
    <%= link_to "GitHub", "https://github.com", target: "_blank" %>
  </footer>
</div>
