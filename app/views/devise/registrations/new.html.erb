<!-- app/views/devise/registrations/new.html.erb -->
<div class="sf-auth-page">
  <div class="sf-auth-card">
    <div class="sf-auth-header">
      <div class="sf-nav-logo-icon" style="width:48px;height:48px;font-size:22px;margin:0 auto 16px;">P</div>
      <h2>Criar conta</h2>
      <p>Começa a gerar schemas com IA</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="sf-auth-field">
        <%= f.label :email, class: "sf-auth-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "nome@email.com", class: "sf-auth-input" %>
      </div>

      <div class="sf-auth-field">
        <%= f.label :password, "Password", class: "sf-auth-label" %>
        <% if @minimum_password_length %>
          <small class="sf-auth-hint">(<%= @minimum_password_length %> caracteres mínimo)</small>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••", class: "sf-auth-input" %>
      </div>

      <div class="sf-auth-field">
        <%= f.label :password_confirmation, "Confirmar password", class: "sf-auth-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", class: "sf-auth-input" %>
      </div>

      <div class="sf-auth-actions">
        <%= f.submit "Criar conta", class: "sf-btn-primary sf-btn-full" %>
      </div>
    <% end %>

    <div class="sf-auth-links">
      <%= link_to "Já tenho conta", new_session_path(resource_name), class: "sf-auth-link" %>
    </div>
  </div>
</div>
