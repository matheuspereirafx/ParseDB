<!-- app/views/devise/passwords/new.html.erb -->
<div class="sf-auth-page">
  <div class="sf-auth-card">
    <div class="sf-auth-header">
      <div class="sf-nav-logo-icon" style="width:48px;height:48px;font-size:22px;margin:0 auto 16px;">P</div>
      <h2>Recuperar password</h2>
      <p>Insere o teu email e enviamos instruções para redefinir</p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="sf-auth-field">
        <%= f.label :email, class: "sf-auth-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "nome@email.com", class: "sf-auth-input" %>
      </div>

      <div class="sf-auth-actions">
        <%= f.submit "Enviar instruções", class: "sf-btn-primary sf-btn-full" %>
      </div>
    <% end %>

    <div class="sf-auth-links">
      <%= link_to "Voltar ao login", new_session_path(resource_name), class: "sf-auth-link" %>
      <span class="sf-auth-separator">·</span>
      <%= link_to "Criar conta", new_registration_path(resource_name), class: "sf-auth-link" %>
    </div>
  </div>
</div>
