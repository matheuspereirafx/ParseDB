<!-- app/views/devise/sessions/new.html.erb -->
<div class="sf-auth-page">
  <div class="sf-auth-card">
    <div class="sf-auth-header">
      <div class="sf-nav-logo-icon" style="width:48px;height:48px;font-size:22px;margin:0 auto 16px;">P</div>
      <h2>Bem-vindo de volta</h2>
      <p>Faz login para continuar no Parse DB</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="sf-auth-field">
        <%= f.label :email, class: "sf-auth-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "nome@email.com", class: "sf-auth-input" %>
      </div>

      <div class="sf-auth-field">
        <%= f.label :password, "Password", class: "sf-auth-label" %>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "sf-auth-input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="sf-auth-remember">
          <%= f.check_box :remember_me, class: "sf-auth-checkbox" %>
          <%= f.label :remember_me, "Lembrar-me", class: "sf-auth-remember-label" %>
        </div>
      <% end %>

      <div class="sf-auth-actions">
        <%= f.submit "Entrar", class: "sf-btn-primary sf-btn-full" %>
      </div>
    <% end %>

    <div class="sf-auth-links">
      <%= link_to "Criar conta", new_registration_path(resource_name), class: "sf-auth-link" %>
      <span class="sf-auth-separator">·</span>
      <%= link_to "Esqueci a password", new_password_path(resource_name), class: "sf-auth-link" %>
    </div>
  </div>
</div>
