<%# app/views/chats/index.html.erb %>
<div class="container mt-4">
  <h1>Meus Chats</h1>

  <%= link_to "Novo Chat", new_stack_chat_path(@stack), class: "btn btn-primary mb-3" %>

  <% if @chats.any? %>
    <div class="list-group">
      <% @chats.each do |chat| %>
        <%= link_to stack_chat_path(@stack, chat), class: "list-group-item list-group-item-action" do %>
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-1"><%= chat.title %></h5>
              <small class="text-muted">
                Criado em: <%= chat.created_at.strftime("%d/%m/%Y %H:%M") %>
              </small>
              <% if chat.stack %>
                <span class="badge bg-info ms-2"><%= chat.stack.name %></span>
              <% end %>
            </div>
            <small><%= chat.messages.count %> mensagens</small>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p>Você ainda não tem nenhum chat.</p>
  <% end %>
</div>
