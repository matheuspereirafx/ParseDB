<%# app/views/chats/index.html.erb %>
<div class="container mt-4">
  <h1>My Chats</h1>

  <%= link_to "New Chat", new_chat_path, class: "btn btn-primary mb-3" %>

  <% if @chats.any? %>
    <div class="list-group">
      <% @chats.each do |chat| %>
        <%= link_to chat_path(chat), class: "list-group-item list-group-item-action" do %>
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-1"><%= chat.title %></h5>
              <small class="text-muted">
                Created: <%= chat.created_at.strftime("%Y-%m-%d %H:%M") %>
              </small>
              <% if chat.stack %>
                <span class="badge bg-info ms-2"><%= chat.stack.name %></span>
              <% end %>
            </div>
            <small><%= pluralize(chat.messages.count, 'message') %></small>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info text-center">
      <p class="mb-2">You don't have any chats yet.</p>
      <%= link_to "Create your first chat!", new_chat_path, class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
</div>
