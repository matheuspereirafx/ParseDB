<%# app/views/chats/_form.html.erb %>

<%= form_with model: [@stack, @chat], local: true do |f| %>
  <% if @chat.errors.any? %>
    <div class="alert alert-danger">
      <h5><%= pluralize(@chat.errors.count, "error") %> prohibited this chat from being saved:</h5>
      <ul>
        <% @chat.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, "Chat Title", class: "form-label" %>
    <%= f.text_field :title, class: "form-control", placeholder: "Enter chat title..." %>
    <small class="text-muted">Give your chat a descriptive name</small>
  </div>

  <%= f.submit "Save Chat", class: "btn btn-primary" %>
  <%= link_to "Cancel", stack_path(@stack), class: "btn btn-outline-secondary" %>
<% end %>
