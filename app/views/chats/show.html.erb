<%# app/views/chats/show.html.erb %>
<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8">

      <!-- Cabeçalho do Chat -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0"><%= @chat.title %></h1>
        <%= link_to "← Voltar", chats_path, class: "btn btn-outline-secondary btn-sm" %>
      </div>

      <!-- Área de Mensagens -->
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0">💬 Chat</h5>
        </div>

        <div class="card-body" style="height: 400px; overflow-y: auto;" id="messages">
          <% if @messages.any? %>
            <% @messages.each do |message| %>
              <div class="mb-3 <%= message.role == 'user' ? 'text-end' : 'text-start' %>">
                <div class="d-inline-block p-3 rounded-3 <%= message.role == 'user' ? 'bg-primary text-white' : 'bg-light' %>"
                     style="max-width: 75%;">
                  <strong><%= message.role == 'user' ? '👤 Você' : '🤖 Assistente' %>:</strong>
                  <p class="mb-0 mt-1"><%= message.content %></p>
                  <small class="<%= message.role == 'user' ? 'text-white-50' : 'text-muted' %> d-block mt-1">
                    <%= l(message.created_at, format: :short) if message.created_at %>
                  </small>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center text-muted py-5">
              <h4>👋 Olá!</h4>
              <p>Comece a conversa enviando uma mensagem abaixo.</p>
            </div>
          <% end %>
        </div>

        <!-- Formulário de Mensagem -->
        <div class="card-footer bg-white">
          <%= form_with model: [@chat, Message.new], class: "d-flex gap-2" do |f| %>
            <div class="flex-grow-1">
              <%= f.text_area :content,
                              class: "form-control",
                              rows: 2,
                              placeholder: "Digite sua mensagem...",
                              autofocus: true,
                              required: true %>
            </div>
            <div>
              <%= f.submit "Enviar", class: "btn btn-primary h-100" %>
            </div>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Auto-scroll para nova mensagem -->
<script>
  document.addEventListener("turbo:load", function() {
    const messagesDiv = document.getElementById('messages');
    if (messagesDiv) {
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }
  });
</script>
