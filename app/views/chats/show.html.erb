<div class="chat-page">

  <div class="chat-header">
    <%= link_to "← voltar", stack_chats_path(@stack), class: "back-btn mt-5" %>
    <span class="chat-title"><%= @chat.title %></span>
    <span class="stack-badge"><%= @stack.icon %> <%= @stack.name %></span>
  </div>

  <div class="messages-area" id="messages">
    <% @messages.each do |message| %>
      <div class="message <%= message.role %>">
        <div class="avatar"><%= message.role == 'user' ? current_user.email.first.upcase : '🤖' %></div>
        <div>
          <div class="bubble"><%= simple_format message.content %></div>
          <div class="message-meta">
            <%= message.role == 'user' ? 'Você' : 'Assistente' %> · <%= message.created_at.strftime("%H:%M") %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="input-area">
    <div class="input-container">
      <%= simple_form_for [@stack, @chat, @message] do |f| %>
        <div class="input-wrapper">
          <%= f.input :content,
              label: false,
              as: :text,
              input_html: {
                placeholder: "Descreva seu projeto...",
                rows: 4,
                class: "chat-textarea",
                id: "chat-input"
              } %>
          <%= f.submit "→", class: "send-btn" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  const messages = document.getElementById('messages');
  if (messages) messages.scrollTop = messages.scrollHeight;
</script>
